       IDENTIFICATION DIVISION.
       PROGRAM-ID. PAYROLL.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT PAYROLL-FILE ASSIGN TO "payroll.dat".
           SELECT REPORT-FILE ASSIGN TO "payroll.out".
       DATA DIVISION.
       FILE SECTION.
       FD  PAYROLL-FILE.
       01  PAYROLL-RECORD.
           05 EMP-NAME PIC X(20).
           05 HOURS-WORKED PIC 9(03).
           05 HOURLY-RATE PIC 9(03)V99.
       FD  REPORT-FILE.
       01  REPORT-RECORD PIC X(80).
       WORKING-STORAGE SECTION.
       01  WS-GROSS-PAY PIC 9(05)V99 VALUE ZERO.
       01  WS-TAX PIC 9(05)V99 VALUE ZERO.
       01  WS-NET-PAY PIC 9(05)V99 VALUE ZERO.
       01  WS-STATUS PIC X(10) VALUE SPACES.
       PROCEDURE DIVISION.
       MAIN-PARA.
           OPEN INPUT PAYROLL-FILE.
           OPEN OUTPUT REPORT-FILE.
           PERFORM CALCULATE-PAY.
           PERFORM WRITE-REPORT.
           CLOSE PAYROLL-FILE.
           CLOSE REPORT-FILE.
           STOP RUN.
       CALCULATE-PAY.
           READ PAYROLL-FILE.
           MOVE "ACTIVE" TO WS-STATUS.
           MULTIPLY HOURS-WORKED BY HOURLY-RATE GIVING WS-GROSS-PAY.
           COMPUTE WS-TAX = WS-GROSS-PAY * 0.20.
           SUBTRACT WS-TAX FROM WS-GROSS-PAY GIVING WS-NET-PAY.
           ADD 1 TO HOURS-WORKED.
           DIVIDE WS-NET-PAY BY HOURS-WORKED GIVING HOURLY-RATE.
           IF WS-NET-PAY > 0
               CALL "AUDITPAY" USING WS-NET-PAY
           ELSE
               MOVE "REVIEW" TO WS-STATUS
           END-IF.
       WRITE-REPORT.
           WRITE REPORT-RECORD.
           GOBACK.
