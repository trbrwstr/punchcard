       IDENTIFICATION DIVISION.
       PROGRAM-ID. RPTGEN.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT SALES-FILE ASSIGN TO "sales.dat".
           SELECT SUMMARY-FILE ASSIGN TO "summary.out".
       DATA DIVISION.
       FILE SECTION.
       FD  SALES-FILE.
       01  SALES-RECORD.
           05 SALE-AMOUNT PIC 9(05)V99.
       FD  SUMMARY-FILE.
       01  SUMMARY-RECORD PIC X(80).
       WORKING-STORAGE SECTION.
       01  WS-TOTAL PIC 9(07)V99 VALUE ZERO.
       01  WS-COUNT PIC 9(05) VALUE ZERO.
       01  WS-AVERAGE PIC 9(05)V99 VALUE ZERO.
       PROCEDURE DIVISION.
       REPORT-MAIN.
           OPEN INPUT SALES-FILE.
           OPEN OUTPUT SUMMARY-FILE.
           PERFORM ACCUMULATE-SALES.
           PERFORM EMIT-SUMMARY.
           CLOSE SALES-FILE.
           CLOSE SUMMARY-FILE.
           STOP RUN.
       ACCUMULATE-SALES.
           READ SALES-FILE.
           ADD SALE-AMOUNT TO WS-TOTAL.
           ADD 1 TO WS-COUNT.
           IF WS-COUNT > 0
               DIVIDE WS-TOTAL BY WS-COUNT GIVING WS-AVERAGE
           ELSE
               MOVE ZERO TO WS-AVERAGE
           END-IF.
       EMIT-SUMMARY.
           EVALUATE WS-COUNT
               WHEN 0
                   MOVE "NO SALES" TO SUMMARY-RECORD
               WHEN OTHER
                   COMPUTE WS-AVERAGE = WS-TOTAL / WS-COUNT
           END-EVALUATE.
           MULTIPLY WS-AVERAGE BY 2 GIVING WS-AVERAGE.
           SUBTRACT 5 FROM WS-TOTAL.
           CALL "RPTAUDIT" USING WS-TOTAL.
           WRITE SUMMARY-RECORD.
           GOBACK.
